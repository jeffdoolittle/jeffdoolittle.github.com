---
import Base from './Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
  showRecents?: boolean;
}

const { title, description, showRecents = true } = Astro.props;

let recentPosts: CollectionEntry<'blog'>[] = [];
if (showRecents) {
  const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
  recentPosts = allPosts
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);
}

const dateFormat = (d: Date | string) => new Date(d).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});
---

<Base title={title} description={description}>
  <div class="wrapper">
    <article class="post">
      <div class="post-content">
        <slot />

        {showRecents && recentPosts.length > 0 && (
          <>
            <hr />
            <h2>Recent Posts</h2>
            <div class="blog-index">
              <ul class="entries">
                {recentPosts.map(post => (
                  <li>
                    <div class="entry-date">{dateFormat(post.data.date)}</div>
                    <div class="entry-text">
                      <a href={`/${post.data.date.getFullYear().toString().padStart(4,'0')}/${(post.data.date.getMonth()+1).toString().padStart(2,'0')}/${post.data.date.getDate().toString().padStart(2,'0')}/${post.slug}/`}>
                        {post.data.title}
                      </a>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </>
        )}

        <hr />
        <div class="flexgrid">
          <div class="row">
            <div class="column">
              <a href="/rss" target="_blank">
                <div><i class="fas fa-rss"></i></div>
                <div>Subscribe</div>
              </a>
            </div>
            <div class="column">
              <a href="https://twitter.com/jeffdoolittle" target="_blank">
                <div><i class="fab fa-twitter-square"></i></div>
                <div>Follow</div>
              </a>
            </div>
            <div class="column">
              <a href="/archive">
                <div><i class="fas fa-archive"></i></div>
                <div>Archives</div>
              </a>
            </div>
          </div>
        </div>
        <hr />
      </div>
    </article>

    <div class="small-banner">
      <img src="/assets/circle_head_shot_2025_small.png" />
    </div>
  </div>
</Base>
