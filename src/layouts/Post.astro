---
import Base from './Base.astro';
import SERadioPlug from '../components/SERadioPlug.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  prev?: { url: string; title: string } | null;
  next?: { url: string; title: string } | null;
}

const { post, prev, next } = Astro.props;
const { title, excerpt, image, image_alt, date, tags = [], category, episode_url } = post.data;
const isSeRadio = category === 'se-radio';

const { year, month, day } = Astro.params as { year: string; month: string; day: string };
const dateStr = (year && month && day)
  ? new Date(`${year}-${month}-${day}T00:00:00Z`).toLocaleDateString('en-US', {
      timeZone: 'UTC', month: 'long', day: 'numeric', year: 'numeric'
    })
  : '';

const pageUrl = Astro.url.pathname;
---

<Base title={title} description={excerpt || undefined} image={image || undefined}>
  <div class="page-hero">
    <div class="page-hero__inner wrapper">
      <div class="page-hero__body">
        <div class="page-hero__text">
          <p class="page-hero__eyebrow">{category ? category.charAt(0).toUpperCase() + category.slice(1) : 'Article'}</p>
          <h1 class="page-hero__title">{title}</h1>
          {dateStr && <p class="page-hero__meta">{dateStr}</p>}
        </div>
      </div>
    </div>
  </div>

  <div class="wrapper">
    <article class="post h-entry" itemscope itemtype="http://schema.org/BlogPosting">

      {image && (
        <div class="post-hero-image">
          <a href={image} title={image_alt || title}>
            <img src={image} alt={image_alt || title} />
          </a>
        </div>
      )}

      <div class="post-content e-content" itemprop="articleBody">
        {excerpt && (
          <p class="post-excerpt"><em>{excerpt}</em></p>
        )}

        <slot />

        {isSeRadio && episode_url && (
          <>
            <p><a href={episode_url} target="_blank" rel="noopener noreferrer">{title}</a> on Software Engineering Radio.</p>
            <p><a href={episode_url} target="_blank" rel="noopener noreferrer">Go give it a listen</a> and be sure to share with your colleagues.</p>
            <SERadioPlug />
          </>
        )}

        <hr />
        <div class="flexgrid">
          <div class="row">
            <div class="column">
              <a href="/feed.xml" target="_blank">
                <div><i class="fas fa-rss"></i></div>
                <div>Subscribe</div>
              </a>
            </div>
            <div class="column">
              <a href="https://www.linkedin.com/in/jeffdoolittle/" target="_blank" rel="noopener noreferrer">
                <div><i class="fab fa-linkedin"></i></div>
                <div>Connect</div>
              </a>
            </div>
            <div class="column">
              <a href="/archive">
                <div><i class="fas fa-archive"></i></div>
                <div>Archives</div>
              </a>
            </div>
          </div>
        </div>
        <hr />
      </div>

      <div class="post-navigation">
        <p><b>Looking for more?</b></p>
        <div class="row">
          <div class="column previous">
            {prev && (
              <a href={prev.url}><i class="fa fa-arrow-left"></i> {prev.title}</a>
            )}
          </div>
          <div class="column delimiter">
            {prev && next && <i class="fa fa-star"></i>}
          </div>
          <div class="column next">
            {next && (
              <a href={next.url}>{next.title} <i class="fa fa-arrow-right"></i></a>
            )}
          </div>
        </div>
      </div>

      <a class="u-url" href={pageUrl} hidden></a>
    </article>
  </div>
</Base>
