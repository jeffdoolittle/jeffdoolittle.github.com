---
import type { CollectionEntry } from 'astro:content';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import Search from 'astro-pagefind/components/Search';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Software Architect. Strategic Business Leader. I help make good software professionals great!",
  image = "/assets/og_image.png",
  canonicalUrl,
} = Astro.props;

const siteTitle = "Jeff Doolittle";
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/publications/", label: "Publications" },
  { href: "/leadership/", label: "Leadership" },
  { href: "/mentoring/", label: "Mentoring" },
  { href: "/about/", label: "About" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="google-site-verification" content="BgAxiKAjf4GKG8eppgT7EZAO0fIuvpTWaKqY43CdSWo" />

  <!-- No-flash theme init: runs before CSS paints -->
  <script is:inline>
    (function() {
      function getCookie(name) {
        var m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
        return m ? decodeURIComponent(m[1]) : null;
      }
      var saved = getCookie('theme');
      var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>

  <title>{pageTitle}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:type" content="website" />

  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" sizes="180x180" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="stylesheet" href="/main.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />

  <!-- Lightbox CSS -->
  <link rel="stylesheet" href="/lightbox.css" />

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="Jeff Doolittle" href="/feed.xml" />

  <!-- Font Awesome -->
  <script src="https://kit.fontawesome.com/2202cfd9ba.js" crossorigin="anonymous" is:inline></script>

  <GoogleAnalytics />
</head>
<body>

  <header class="site-header" role="banner">
    <div class="site-header__inner">
      <a class="site-title" rel="author" href="/">Jeff Doolittle</a>

      <nav class="site-nav">
        <input type="checkbox" id="nav-trigger" class="nav-trigger" />
        <label for="nav-trigger">
          <span class="menu-icon">
            <svg viewBox="0 0 18 15" width="18px" height="15px">
              <path d="M18,1.484c0,0.82-0.665,1.484-1.484,1.484H1.484C0.665,2.969,0,2.304,0,1.484l0,0C0,0.665,0.665,0,1.484,0 h15.032C17.335,0,18,0.665,18,1.484L18,1.484z M18,7.516C18,8.335,17.335,9,16.516,9H1.484C0.665,9,0,8.335,0,7.516l0,0 c0-0.82,0.665-1.484,1.484-1.484h15.032C17.335,6.031,18,6.696,18,7.516L18,7.516z M18,13.516C18,14.335,17.335,15,16.516,15H1.484 C0.665,15,0,14.335,0,13.516l0,0c0-0.82,0.665-1.483,1.484-1.483h15.032C17.335,12.031,18,12.695,18,13.516L18,13.516z"/>
            </svg>
          </span>
        </label>

        <div class="trigger">
          {navLinks.map(link => (
            <a class="page-link" href={link.href}>{link.label}</a>
          ))}
        </div>
      </nav>

      <!-- Pagefind Search -->
      <Search id="search-wrapper" className="pagefind-search" />

      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <svg class="theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>

      <script is:inline>
        (function() {
          function getCookie(name) {
            var m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
            return m ? decodeURIComponent(m[1]) : null;
          }
          function setCookie(name, value, days) {
            var expires = new Date(Date.now() + days * 864e5).toUTCString();
            document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/; SameSite=Lax';
          }
          var btn = document.getElementById('theme-toggle');
          function syncIcon(theme) {
            btn.setAttribute('data-theme', theme);
          }
          syncIcon(document.documentElement.getAttribute('data-theme') || 'light');
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme') || 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            setCookie('theme', next, 365);
            syncIcon(next);
          });
        })();
      </script>
    </div>
  </header>

  <main class="page-content" aria-label="Content">
    <slot />
  </main>

  <footer class="site-footer h-card">
    <data class="u-url" href="/"></data>
    <div class="footer-inner">
      <div class="footer-col footer-col-3">
        <a class="footer-brand__name" href="/">Jeff Doolittle</a>
        <p class="footer-brand__desc">Software Architect. Strategic Business Leader. I help make good software professionals great!</p>
      </div>
      <div class="footer-col footer-col-3">
        <h5 class="footer-heading">Navigate</h5>
        <ul class="footer-links">
          <li><a href="/publications/">Publications</a></li>
          <li><a href="/leadership/">Leadership</a></li>
          <li><a href="/mentoring/">Mentoring</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/archive/">Archive</a></li>
        </ul>
      </div>
      <div class="footer-col footer-col-3">
        <h5 class="footer-heading">Connect</h5>
        <div class="social">
          <a target="_blank" title="GitHub" href="/github"><i style="margin-right: .3em;" class="social-link fab fa-github"></i></a>
          <a target="_blank" title="LinkedIn" href="/linkedin"><i style="margin-right: .3em;" class="social-link fab fa-linkedin"></i></a>
          <a target="_blank" title="Stack Overflow" href="/stackoverflow"><i style="margin-right: .3em;" class="social-link fab fa-stack-overflow"></i></a>
          <a target="_blank" title="ORCiD" href="/orcid"><i style="margin-right: .3em;" class="social-link fab fa-orcid"></i></a>
          <a target="_blank" title="Twitter" href="/twitter"><i style="margin-right: .3em;" class="social-link fab fa-twitter"></i></a>
          <a target="_blank" title="YouTube" href="/youtube"><i style="margin-right: .3em;" class="social-link fab fa-youtube"></i></a>
          <a target="_blank" title="SoundCloud" href="/soundcloud"><i style="margin-right: .3em;" class="social-link fab fa-soundcloud"></i></a>
          <a target="_blank" title="RSS" href="/rss"><i style="margin-right: .3em;" class="social-link fas fa-rss"></i></a>
        </div>
        <p><a class="u-email" href="mailto:jeff@jeffdoolittle.com">jeff@jeffdoolittle.com</a></p>
        <p><a href="https://keybase.io/jeffdoolittle/pgp_keys.asc" target="_blank">4B1B B252 C58A 118C</a></p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>All contents &copy; 2018-{currentYear} Jeff Doolittle. All rights reserved.</p>
      <p><a href="https://github.com/jeffdoolittle/jeffdoolittle.github.com" target="_blank">Last updated</a>: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
    </div>
  </footer>

  <!-- jQuery + Lightbox -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.4.1/jquery.min.js" is:inline></script>
  <script is:inline src="/lightbox.js"></script>

</body>
</html>
