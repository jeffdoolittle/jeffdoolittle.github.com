---
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import { postUrl, formatDate, slugDate } from '../utils/post';
import { Image } from 'astro:assets';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Archive">
  <div class="page-hero">
    <div class="page-hero__inner wrapper">
      <div class="page-hero__body">
        <div class="page-hero__text">
          <h1 class="page-hero__title">Post Archive</h1>
        </div>
        <div class="page-hero__avatar">
          <Image src="/assets/circle_head_shot_2025_small.png" alt="Jeff Doolittle" width={256} height={256} format="webp" quality={70} loading="eager" />
        </div>
      </div>
    </div>
  </div>
  <div class="wrapper">
    <div class="home">
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <span class="post-meta">{formatDate(slugDate(post), 'short')}</span>
            <hr />
            <h3>
              <a class="post-link" href={postUrl(post)}>{post.data.title}</a>
            </h3>
            {post.data.excerpt && (
              <>
                <p><em>{post.data.excerpt}</em></p>
                <a href={postUrl(post)}>
                  {post.data.image && <p><img src={post.data.image} alt={post.data.image_alt || post.data.title} /></p>}
                  <p>Continue reading...</p>
                </a>
              </>
            )}
          </li>
        ))}
      </ul>

      <hr />
      <div class="flexgrid">
        <div class="row">
          <div class="column">
            <a href="/feed.xml" target="_blank">
              <div><span class="icon-logo fas fa-rss" aria-hidden="true"></span></div>
              <div>Subscribe</div>
            </a>
          </div>
          <div class="column">
            <a href="https://www.linkedin.com/in/jeffdoolittle/" target="_blank" rel="noopener noreferrer">
              <div><span class="icon-logo fab fa-linkedin-in" aria-hidden="true"></span></div>
              <div>Connect</div>
            </a>
          </div>
          <div class="column">
            <a href="/archive">
              <div><span class="icon-logo fas fa-archive" aria-hidden="true"></span></div>
              <div>Archives</div>
            </a>
          </div>
        </div>
      </div>
      <hr />
    </div>
  </div>
</Base>
