---
import Base from './Base.astro';
import Highlights from '../components/Highlights.astro';
import PostGrid from '../components/PostGrid.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 25);
---

<Base>
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__avatar">
        <img src="/assets/circle_head_shot_2025_small.png" alt="Jeff Doolittle" />
      </div>
      <h1 class="hero__title">Jeff Doolittle</h1>
      <p class="hero__tagline">
        <span class="hero__tagline--primary">Software Architect. Strategic Business Leader.</span><br />
        <span class="hero__tagline--accent">I help make good software professionals great.</span>
      </p>
      <div class="hero__cta">
        <a class="btn btn-primary" href="/about/">About Me</a>
        <a class="btn btn-ghost" href="/publications/">Explore Publications</a>
      </div>
    </div>
  </section>

  <div class="wrapper">
    <div class="home">
      <div class="home-content">
        <div class="home-section">
          <div class="section-header">
            <h2 class="section-title">Latest by Topic</h2>
            <div class="section-divider"></div>
            <a class="section-link" href="/publications/">All Publications →</a>
          </div>
          <Highlights />
        </div>

        <div class="home-section">
          <div class="section-header">
            <h2 class="section-title">Recent Writing</h2>
            <div class="section-divider"></div>
            <a class="section-link" href="/archive/">Full Archive →</a>
          </div>
          <PostGrid posts={recentPosts} />
        </div>

        <hr />
        <div class="flexgrid">
          <div class="row">
            <div class="column">
              <a href="/feed.xml" target="_blank">
                <div><i class="fas fa-rss"></i></div>
                <div>Subscribe</div>
              </a>
            </div>
            <div class="column">
              <a href="https://www.linkedin.com/in/jeffdoolittle/" target="_blank" rel="noopener noreferrer">
                <div><i class="fab fa-linkedin"></i></div>
                <div>Connect</div>
              </a>
            </div>
            <div class="column">
              <a href="/archive">
                <div><i class="fas fa-archive"></i></div>
                <div>Archives</div>
              </a>
            </div>
          </div>
        </div>
        <hr />
      </div>
    </div>

    <div class="small-banner wrapper">
      <img src="/assets/circle_head_shot_2025_small.png" />
    </div>
  </div>
</Base>
