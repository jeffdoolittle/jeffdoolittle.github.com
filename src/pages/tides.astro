---
import Page from '../layouts/Page.astro';
---

<Page title="Low Tide Finder" description="NOAA low-tide finder for Clatsop County, Oregon and Long Beach-area Washington beaches.">
  <h2>NOAA Low Tide Finder</h2>
  <p>
    This page checks NOAA tide predictions and reports low tides at <strong>-0.8 ft or lower</strong>
    for Clatsop County, Oregon beaches and southern Washington (Long Beach area).
  </p>

  <div class="tide-controls" aria-label="Low tide filters">
    <label>
      Start date
      <input id="start-date" type="date" />
    </label>
    <label>
      Days
      <select id="day-range">
        <option value="60">60</option>
        <option value="90" selected>90</option>
        <option value="120">120</option>
      </select>
    </label>
    <label>
      Threshold (ft)
      <input id="threshold" type="text" inputmode="decimal" value="-.8" />
    </label>
    <label>
      Highlight cutoff (ft)
      <input id="highlight-threshold" type="text" inputmode="decimal" value="-1" />
    </label>
    <button id="refresh-tides" class="btn btn-primary" type="button">Refresh</button>
    <button id="refresh-live" class="btn" type="button">Refresh Live NOAA</button>
  </div>

  <p id="validation-feedback" class="tide-feedback" aria-live="polite"></p>

  <p id="status" class="tide-status" aria-live="polite">Loading tide predictions...</p>

  <section id="results" class="tide-results" aria-live="polite"></section>

  <p class="tide-note">
    Notes: Predictions are NOAA station-based proxies, not exact beach spot measurements. Tide conditions can vary by location,
    weather, swell, and barometric pressure.
  </p>

  <script is:inline>
    (function() {
      var THRESHOLD_MIN = -10;
      var THRESHOLD_MAX = 10;
      var CACHE_DB_NAME = 'noaa-tides-cache-v1';
      var CACHE_STORE = 'noaaPredictions';
      var CACHE_TTL_MS = 6 * 60 * 60 * 1000;

      var STATIONS = [
        {
          id: '9439011',
          name: 'Hammond, OR',
          area: 'Clatsop County beaches (Fort Stevens, Sunset Beach, Seaside)',
        },
        {
          id: '9439040',
          name: 'Astoria, OR',
          area: 'Clatsop County estuary context',
        },
        {
          id: '9440910',
          name: 'Toke Point, WA',
          area: 'Long Beach peninsula area (southern Washington)',
        },
      ];

      var startDateInput = document.getElementById('start-date');
      var dayRangeInput = document.getElementById('day-range');
      var thresholdInput = document.getElementById('threshold');
      var highlightThresholdInput = document.getElementById('highlight-threshold');
      var refreshButton = document.getElementById('refresh-tides');
      var refreshLiveButton = document.getElementById('refresh-live');
      var validationFeedbackEl = document.getElementById('validation-feedback');
      var statusEl = document.getElementById('status');
      var resultsEl = document.getElementById('results');

      function toYyyymmdd(dateText) {
        return (dateText || '').replace(/-/g, '');
      }

      function addDays(dateText, days) {
        var date = new Date(dateText + 'T00:00:00');
        date.setDate(date.getDate() + days);
        return date.toISOString().slice(0, 10);
      }

      function formatFeet(value) {
        return Number(value).toFixed(2) + ' ft';
      }

      function formatInputValue(value) {
        return Number(value).toFixed(1).replace(/\.0$/, '');
      }

      function normalizeNumericText(value) {
        var text = String(value || '').trim();
        if (!text) return text;
        if (text === '.') return '0.';
        if (text === '-.') return '-0.';
        if (text.charAt(0) === '.') return '0' + text;
        if (text.indexOf('-.') === 0) return '-0' + text.slice(1);
        return text;
      }

      function parseThresholdValue(value, label) {
        var normalized = normalizeNumericText(value);
        var parsed = Number(normalized);

        if (!Number.isFinite(parsed)) {
          return { ok: false, message: label + ' must be a number between ' + THRESHOLD_MIN + ' and ' + THRESHOLD_MAX + '.' };
        }

        if (parsed < THRESHOLD_MIN || parsed > THRESHOLD_MAX) {
          return { ok: false, message: label + ' must be between ' + THRESHOLD_MIN + ' and ' + THRESHOLD_MAX + ' ft.' };
        }

        return { ok: true, value: parsed };
      }

      function setValidationFeedback(message) {
        validationFeedbackEl.textContent = message || '';
      }

      function formatDateTime(localText) {
        var parsed = new Date(localText.replace(' ', 'T'));
        if (Number.isNaN(parsed.getTime())) return localText;
        return parsed.toLocaleString([], {
          weekday: 'short',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
        });
      }

      function renderNoData(station) {
        return '<article class="tide-card">' +
          '<h3>' + station.name + '</h3>' +
          '<p class="tide-area">' + station.area + '</p>' +
          '<p class="tide-empty">No low tides at or below threshold in the selected range.</p>' +
          '</article>';
      }

      function renderStation(station, lows, threshold, highlightCutoff) {
        if (!lows.length) return renderNoData(station);

        var rows = lows.map(function(item) {
          var value = Number(item.v);
          var isVeryLow = value <= highlightCutoff;
          var rowClass = isVeryLow ? ' class="tide-list__item tide-list__item--very-low"' : ' class="tide-list__item"';
          return '<li' + rowClass + '><span class="tide-list__time">' + formatDateTime(item.t) + '</span><strong class="tide-list__value">' + formatFeet(value) + '</strong></li>';
        }).join('');

        return '<article class="tide-card">' +
          '<h3>' + station.name + '</h3>' +
          '<p class="tide-area">' + station.area + '</p>' +
          '<p class="tide-count">Found ' + lows.length + ' low tide(s) <= ' + formatFeet(threshold) + '</p>' +
          '<ul class="tide-list">' + rows + '</ul>' +
          '</article>';
      }

      function buildUrl(stationId, beginDate, rangeHours) {
        var params = new URLSearchParams({
          product: 'predictions',
          application: 'jeffdoolittle-low-tides',
          begin_date: beginDate,
          range: String(rangeHours),
          datum: 'MLLW',
          station: stationId,
          time_zone: 'lst_ldt',
          units: 'english',
          interval: 'hilo',
          format: 'json',
        });
        return 'https://api.tidesandcurrents.noaa.gov/api/prod/datagetter?' + params.toString();
      }

      function parseLows(predictions, threshold) {
        if (!Array.isArray(predictions)) return [];
        return predictions
          .filter(function(item) {
            return item.type === 'L' && Number(item.v) <= threshold;
          })
          .sort(function(a, b) {
            return new Date(a.t.replace(' ', 'T')).getTime() - new Date(b.t.replace(' ', 'T')).getTime();
          });
      }

      function cacheKey(stationId, beginDate, rangeHours) {
        return stationId + ':' + beginDate + ':' + rangeHours;
      }

      function openCacheDb() {
        return new Promise(function(resolve, reject) {
          if (!('indexedDB' in window)) {
            resolve(null);
            return;
          }

          var request = window.indexedDB.open(CACHE_DB_NAME, 1);
          request.onupgradeneeded = function(event) {
            var db = event.target.result;
            if (!db.objectStoreNames.contains(CACHE_STORE)) {
              db.createObjectStore(CACHE_STORE, { keyPath: 'key' });
            }
          };
          request.onsuccess = function(event) {
            resolve(event.target.result);
          };
          request.onerror = function() {
            reject(request.error || new Error('IndexedDB unavailable'));
          };
        });
      }

      async function readCacheRecord(key) {
        try {
          var db = await openCacheDb();
          if (!db) return null;

          return await new Promise(function(resolve, reject) {
            var tx = db.transaction(CACHE_STORE, 'readonly');
            var store = tx.objectStore(CACHE_STORE);
            var request = store.get(key);
            request.onsuccess = function() { resolve(request.result || null); };
            request.onerror = function() { reject(request.error || new Error('Cache read failed')); };
          });
        } catch (error) {
          console.info('[tides-cache] unavailable for read', error);
          return null;
        }
      }

      async function writeCacheRecord(key, payload) {
        try {
          var db = await openCacheDb();
          if (!db) return;

          await new Promise(function(resolve, reject) {
            var tx = db.transaction(CACHE_STORE, 'readwrite');
            var store = tx.objectStore(CACHE_STORE);
            var request = store.put({ key: key, savedAt: Date.now(), payload: payload });
            request.onsuccess = function() { resolve(); };
            request.onerror = function() { reject(request.error || new Error('Cache write failed')); };
          });
        } catch (error) {
          console.info('[tides-cache] unavailable for write', error);
        }
      }

      async function fetchChunkPredictions(stationId, beginDate, rangeHours, forceLive, stats) {
        var key = cacheKey(stationId, beginDate, rangeHours);
        var cachedRecord = await readCacheRecord(key);
        var hasFreshCache = cachedRecord && (Date.now() - cachedRecord.savedAt) <= CACHE_TTL_MS;

        if (!forceLive && hasFreshCache) {
          stats.cacheHits += 1;
          console.info('[tides-cache] hit', key);
          return { predictions: cachedRecord.payload.predictions || [], fromStaleCache: false };
        }

        if (cachedRecord && !hasFreshCache) {
          stats.staleSeen += 1;
          console.info('[tides-cache] stale', key);
        } else {
          stats.cacheMisses += 1;
          console.info('[tides-cache] miss', key);
        }

        try {
          var response = await fetch(buildUrl(stationId, beginDate, rangeHours));
          var payload = await response.json();
          if (!response.ok || payload.error) {
            var message = payload && payload.error ? payload.error.message : 'Unknown NOAA API error';
            throw new Error(message);
          }

          await writeCacheRecord(key, payload);
          stats.networkLoads += 1;
          console.info('[tides-cache] stored', key);
          return { predictions: payload.predictions || [], fromStaleCache: false };
        } catch (error) {
          if (cachedRecord && cachedRecord.payload && Array.isArray(cachedRecord.payload.predictions)) {
            stats.staleFallbacks += 1;
            console.info('[tides-cache] stale fallback', key);
            return { predictions: cachedRecord.payload.predictions, fromStaleCache: true };
          }
          throw error;
        }
      }

      async function fetchStation(station, startDate, days, threshold, forceLive, stats) {
        var predictions = [];
        var usedStaleFallback = false;

        for (var offset = 0; offset < days; offset += 30) {
          var chunkDays = Math.min(30, days - offset);
          var chunkStart = addDays(startDate, offset);
          var beginDate = toYyyymmdd(chunkStart);
          var rangeHours = chunkDays * 24;

          var chunk = await fetchChunkPredictions(station.id, beginDate, rangeHours, forceLive, stats);
          predictions = predictions.concat(chunk.predictions || []);
          usedStaleFallback = usedStaleFallback || chunk.fromStaleCache;
        }

        return {
          station: station,
          lows: parseLows(predictions, threshold),
          usedStaleFallback: usedStaleFallback,
        };
      }

      async function refresh(forceLive) {
        var startDate = startDateInput.value;
        var days = Number(dayRangeInput.value);
        var thresholdResult = parseThresholdValue(thresholdInput.value, 'Threshold');
        var highlightResult = parseThresholdValue(highlightThresholdInput.value, 'Highlight cutoff');

        if (!thresholdResult.ok) {
          setValidationFeedback(thresholdResult.message);
          statusEl.textContent = 'Please fix the threshold value and try again.';
          return;
        }

        if (!highlightResult.ok) {
          setValidationFeedback(highlightResult.message);
          statusEl.textContent = 'Please fix the highlight cutoff and try again.';
          return;
        }

        var threshold = thresholdResult.value;
        var highlightCutoff = highlightResult.value;

        if (!startDate || !Number.isFinite(days) || days <= 0) {
          statusEl.textContent = 'Please provide a valid date, day range, and threshold.';
          return;
        }

        thresholdInput.value = formatInputValue(threshold);
        highlightThresholdInput.value = formatInputValue(highlightCutoff);
        setValidationFeedback('');

        statusEl.textContent = forceLive ? 'Loading NOAA predictions (live refresh)...' : 'Loading NOAA predictions...';
        resultsEl.innerHTML = '';

        var stats = {
          cacheHits: 0,
          cacheMisses: 0,
          staleSeen: 0,
          staleFallbacks: 0,
          networkLoads: 0,
        };

        try {
          var groups = await Promise.all(
            STATIONS.map(function(station) {
              return fetchStation(station, startDate, days, threshold, forceLive, stats);
            })
          );

          var totalLows = groups.reduce(function(sum, group) {
            return sum + group.lows.length;
          }, 0);

          var staleUsed = groups.some(function(group) {
            return group.usedStaleFallback;
          });

          resultsEl.innerHTML = groups.map(function(group) {
            return renderStation(group.station, group.lows, threshold, highlightCutoff);
          }).join('');

          var suffix = staleUsed ? ' Some entries used stale cached data due to network/API issues.' : '';
          statusEl.textContent = 'Found ' + totalLows + ' qualifying low tide(s) across ' + STATIONS.length + ' NOAA stations.' + suffix;
          console.info('[tides-cache] stats', stats);
        } catch (error) {
          resultsEl.innerHTML = '';
          statusEl.textContent = 'Could not load NOAA predictions right now. ' + (error && error.message ? error.message : 'Please try again.');
        }
      }

      var today = new Date();
      startDateInput.value = today.toISOString().slice(0, 10);

      refreshButton.addEventListener('click', function() { refresh(false); });
      refreshLiveButton.addEventListener('click', function() { refresh(true); });
      thresholdInput.addEventListener('blur', function() {
        var thresholdResult = parseThresholdValue(thresholdInput.value, 'Threshold');
        if (thresholdResult.ok) {
          thresholdInput.value = formatInputValue(thresholdResult.value);
          setValidationFeedback('');
        } else {
          setValidationFeedback(thresholdResult.message);
        }
      });
      highlightThresholdInput.addEventListener('blur', function() {
        var highlightResult = parseThresholdValue(highlightThresholdInput.value, 'Highlight cutoff');
        if (highlightResult.ok) {
          highlightThresholdInput.value = formatInputValue(highlightResult.value);
          setValidationFeedback('');
        } else {
          setValidationFeedback(highlightResult.message);
        }
      });

      refresh(false);
    })();
  </script>
</Page>

<style is:global>
  .tide-controls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.9rem;
    align-items: end;
    margin: 1rem 0 1.25rem;
  }

  .tide-controls label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-weight: 600;
    color: var(--body-text, #d6e0ea);
  }

  .tide-controls input,
  .tide-controls select {
    border: 1px solid var(--section-border, #35506a);
    border-radius: 0.5rem;
    padding: 0.55rem 0.6rem;
    background: var(--surface, #122231);
    color: inherit;
  }

  .tide-controls .btn {
    width: 100%;
  }

  .tide-feedback {
    margin: 0.1rem 0 0.35rem;
    color: var(--amber);
    min-height: 1.2em;
    font-weight: 600;
  }

  .tide-status {
    margin: 0.25rem 0 1rem;
    font-weight: 600;
    color: var(--section-title, #7db6ff);
  }

  .tide-results {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .tide-card {
    border: 1px solid var(--section-border, #35506a);
    border-radius: 0.75rem;
    padding: 0.95rem;
    background: linear-gradient(170deg, rgba(21, 43, 63, 0.82), rgba(12, 27, 41, 0.82));
  }

  .tide-card h3 {
    margin: 0;
  }

  .tide-area {
    margin: 0.3rem 0 0.75rem;
    opacity: 0.9;
    font-size: 0.95rem;
  }

  .tide-count {
    margin: 0 0 0.6rem;
    font-weight: 600;
    color: var(--link-color, #8ecbff);
  }

  .tide-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .tide-list__item {
    display: flex;
    justify-content: space-between;
    gap: 1.4rem;
    border-top: 1px dashed rgba(126, 172, 211, 0.35);
    padding-top: 0.45rem;
  }

  .tide-list__time {
    padding-right: 0.8rem;
  }

  .tide-list__value {
    min-width: 5.25rem;
    text-align: right;
  }

  .tide-list__item--very-low .tide-list__time,
  .tide-list__item--very-low .tide-list__value {
    color: var(--amber);
    font-weight: 700;
  }

  .tide-empty {
    margin: 0;
    opacity: 0.92;
  }

  .tide-note {
    margin-top: 1.1rem;
    font-size: 0.95rem;
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .tide-controls {
      grid-template-columns: 1fr;
    }
  }
</style>
