---
import Base from '../layouts/Base.astro';

export const prerender = true;
---
<Base title="Schedule" description="Schedule time with Jeff Doolittle">
  <div class="wrapper" style="padding-top: 2rem; padding-bottom: 2rem;">
    <h1>Schedule Time</h1>
    <p>
      The scheduling calendar is hosted on Calendly.
      Use the link below to continue.
    </p>
    <p>
      <a href="https://calendly.com/jeffdoolittle" target="_blank" rel="noopener noreferrer">
        Open Jeff Doolittle's Calendly page
      </a>
    </p>
  </div>
</Base>
