---
import Page from '../layouts/Page.astro';
import PageNav from '../components/PageNav.astro';
import { getCollection } from 'astro:content';
import { postUrl, formatDate } from '../utils/post';
import categoriesData from '../data/categories';

const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
const sorted = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = categoriesData as Array<{
  id: string;
  title: string;
  subtitle: string;
  bio?: string;
  bioTitle?: string;
  entriesHeader: string;
}>;
---
<Page title="Publications" showRecents={false}>
  <PageNav entries={[
    { title: 'Leadership', href: '#leadership' },
    { title: 'Events', href: '#events' },
    { title: 'Software Engineering Radio', href: '#se-radio' },
    { title: 'Music', href: '#music' },
  ]} />

  <h1>Publications</h1>

  {categories.filter(c => ['leadership', 'events', 'se-radio', 'music'].includes(c.id)).map((category) => {
    const posts = sorted.filter(p => p.data.category === category.id);
    return (
      <>
        <h2 id={category.id} style="margin-bottom: .5em">
          {category.title}{' '}
          <span style="float: right; vertical-align: center; font-size: .5em">^ <a href="#top">top</a></span>
        </h2>
        <p><em>{category.subtitle}</em></p>
        {category.bio && (
          <p><a href={category.bio} target="_blank" rel="noopener noreferrer">{category.bioTitle}</a></p>
        )}
        <h3>{category.entriesHeader}</h3>
        <ul class="entries">
          {posts.map(post => (
            <li>
              <div class="entry-date">{formatDate(post.data.date)}</div>
              <div class="entry-text">
                <a href={postUrl(post)}>{post.data.title}</a>
              </div>
            </li>
          ))}
        </ul>
        <p><hr /></p>
      </>
    );
  })}
</Page>
