---
import portfolioData from '../data/portfolio';

const { projects } = portfolioData as { projects: Array<{ title: string; summary: string; content: string }> };
---

{projects.map(p => (
  <>
    <h3>{p.title}</h3>
    <blockquote><h4 style="color: var(--amber)">{p.summary}</h4></blockquote>
    <div set:html={p.content} />
  </>
))}
